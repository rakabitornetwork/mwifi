# Konfigurasi proses Node gateway (bukan pengaturan Laravel).
# Integrasi mwifi (URL, session, API key) dikelola lewat menu Pengaturan di panel admin.

# Port khusus instance mwifi (3001/3002 dipakai aplikasi lain)
PORT=3003

# Session default — harus sama dengan Session ID di panel Pengaturan mwifi
DEFAULT_SESSION=mwifi_session

# Opsional — isi jika juga diisi di panel Pengaturan → API Key
API_KEY=

# Folder penyimpanan sesi WhatsApp (jangan di-commit)
SESSIONS_DIR=./sessions
